# =========================================================================
# fashion-size-fit-prediction — environment variables
# =========================================================================
# Copy this file to .env and adjust the values for your setup.
# The .env file is gitignored and is NEVER committed.

# -------------------------------------------------------------------------
# Kaggle credentials (only needed for automated kagglehub download)
# -------------------------------------------------------------------------
# The raw data (Data Mining Cup 2016) is NOT shipped in this repository —
# Kaggle / competition terms forbid redistribution. You download it yourself
# via kagglehub. Public datasets usually download anonymously; if kagglehub
# asks you to authenticate, create an API token at
# https://www.kaggle.com/settings/account and fill these in.
# Source of the dataset: see DATA.md and LICENSES.md.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# -------------------------------------------------------------------------
# Data cache
# -------------------------------------------------------------------------
# Where kagglehub caches the downloaded dataset. Defaults to the standard
# kagglehub cache (~/.cache/kagglehub) if left unset. The script also looks
# for a local copy under data/raw/.
# KAGGLEHUB_CACHE=~/.cache/kagglehub

# -------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------
# Verbosity for script output: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Random seed
# -------------------------------------------------------------------------
# Used everywhere a stochastic component appears (default 42).
RANDOM_SEED=42
